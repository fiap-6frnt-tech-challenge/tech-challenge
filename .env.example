# Bytebank — variáveis consumidas pelo docker-compose.yml da raiz.
# Copie para `.env` (gitignored): o Docker Compose carrega esse arquivo
# automaticamente para as substituições ${...} do compose.
#
#   cp .env.example .env
#
# (Para rodar o shell em dev fora do compose, use apps/shell/.env.local —
#  veja apps/shell/.env.example, que documenta as vars da aplicação.)

# --- Autenticação (NextAuth v5, lido pelo serviço `shell`) ---
# Segredo de assinatura dos JWTs. Gere um por ambiente com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Se ficar vazio, o compose usa o fallback `dev-secret` (só para smoke local).
AUTH_SECRET=

# --- Upload de anexos (Vercel Blob — opcional) ---
# Token read/write gerado em Vercel > Storage > Blob > Tokens.
# Vazio: o upload de anexos falha graciosamente (storage mock). Ok para o smoke básico.
BLOB_READ_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# Primeiro boot (clone limpo) — migrate + seed rodam FORA do compose:
#
#   docker compose up -d db                 # sobe só o Postgres
#   npm run db:migrate -w @bytebank/shell   # cria as tabelas (transactions, attachments, users)
#   npm run db:seed -w @bytebank/shell      # carrega data/transactions.json
#   docker compose up --build               # sobe shell + dashboard-mfe + transactions-mfe
#
# Login: a imagem do shell roda com NODE_ENV=production, então o atalho de dev
# (`senha123`) fica desativado. Crie uma conta em http://localhost:3000/register
# e faça login com ela.
# -----------------------------------------------------------------------------
