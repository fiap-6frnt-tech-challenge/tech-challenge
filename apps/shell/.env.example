# Bytebank shell — variáveis de ambiente
# Copie este arquivo para .env.local (gitignored) e ajuste os valores.

# API endpoint do shell (Next.js API Routes em /api/*)
NEXT_PUBLIC_API_URL=/api

# URL do manifest do MFE 'hello' (Track A do PoC Module Federation)
# Local: aponta para Rsbuild dev server do hello-mfe
# Vercel: substituir pela URL pública do deploy do hello-mfe
NEXT_PUBLIC_HELLO_MFE_URL=http://localhost:3001/mf-manifest.json

# URL do manifest do MFE 'dashboard' (Sprint 2 — consumido na home `/`)
# Local: aponta para o Rsbuild dev server do dashboard-mfe (apps/dashboard-mfe em :3002)
# Vercel: substituir pela URL pública do deploy do dashboard-mfe
NEXT_PUBLIC_DASHBOARD_MFE_URL=http://localhost:3002/mf-manifest.json

# Persistência (Postgres + Drizzle — Task 2)
# Local (Docker, via docker-compose.yml na raiz): usuário/senha/db = bytebank
# Cloud (Neon): cole a connection string com ?sslmode=require
DATABASE_URL=postgres://bytebank:bytebank@localhost:5432/bytebank

# Autenticação (NextAuth.js)
# URL base do app — obrigatória em produção; em dev padrão é http://localhost:3000
AUTH_URL=http://localhost:3000
# Gere um segredo único para cada ambiente com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Google OAuth (NextAuth.js)
# Configure um app no Google Cloud Console e cole as credenciais aqui.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Vercel Blob (upload de anexos — Sprint 3)
# Gere o token em Vercel > Storage > Blob > Tokens (read/write).
# Sem este token, o app usa um storage mock local (sem upload real) para não quebrar o build.
BLOB_READ_WRITE_TOKEN=