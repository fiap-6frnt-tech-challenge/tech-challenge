{
  "name": "bytebank-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "description": "Bytebank — monorepo Fase 2 (shell + microfrontends + design system)",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "storybook": "turbo run storybook",
    "e2e:build": "NEXT_PUBLIC_DASHBOARD_MFE_URL=http://localhost:3002/mf-manifest.json NEXT_PUBLIC_TRANSACTIONS_MFE_URL=http://localhost:3003/mf-manifest.json NEXT_PUBLIC_API_URL=/api npm run build",
    "e2e": "npm run e2e:build && playwright test",
    "e2e:test": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "turbo": "^2.3.0",
    "prettier": "^3.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,css,md}": [
      "prettier --write"
    ]
  }
}
