{
  "name": "@bytebank/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Bytebank - shared types, utilities and constants",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./lib/*": "./src/lib/*.ts",
    "./constants/*": "./src/constants/*.ts"
  },
  "files": [
    "src"
  ],
  "dependencies": {
    "zod": "^4.3.6"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "typescript": "^5",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.0.18"
  }
}
